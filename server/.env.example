# Application enviroment (development | production)
NODE_ENV=development

# Default application port
PORT=5000

# PostgreSQL configuration
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=servants

# JWT key
JWT_SECRET=your_secret_key

# CORS - Your Vercel frontend URL (e.g. https://your-app.vercel.app)
# Use * to allow all origins (not recommended in production)
CORS_ORIGIN=https://your-app.vercel.app

# Twilio configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_service_sid

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
